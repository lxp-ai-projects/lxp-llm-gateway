@gatewayApiBaseUrl = http://localhost:3001
@userId = REPLACE_WITH_USER_ID

### Health
GET {{gatewayApiBaseUrl}}/health

### Chat Completion
POST {{gatewayApiBaseUrl}}/v1/chat
Content-Type: application/json
x-user-id: {{userId}}

{
  "providerId": "nanogpt",
  "model": "openai/gpt-5.2",
  "messages": [
    {
      "role": "user",
      "content": "Say hello from lxp-llm-gateway."
    }
  ]
}
