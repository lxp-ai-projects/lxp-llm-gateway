### Login
POST {{adminApiBaseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "{{userEmail}}",
  "password": "{{userPassword}}"
}

> {%
    client.global.set("accessToken", response.body.accessToken);
    client.global.set("refreshToken", response.body.refreshToken);
%}

### Resolve Current User
GET {{adminApiBaseUrl}}/api/v1/auth/me
Authorization: Bearer {{accessToken}}

> {%
    client.global.set("userUuid", response.body.userUuid);
%}

### Store NanoGPT Credential
POST {{adminApiBaseUrl}}/api/v1/admin/provider-credentials
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "userUuid": "{{userUuid}}",
  "providerId": "nanogpt",
  "label": "primary",
  "apiToken": "{{providerApiToken}}"
}
