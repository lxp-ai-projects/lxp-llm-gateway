@adminApiBaseUrl = http://localhost:3002
@userId = REPLACE_WITH_USER_ID
@providerApiToken = REPLACE_WITH_NANOGPT_API_TOKEN

### Store NanoGPT Credential
POST {{adminApiBaseUrl}}/admin/provider-credentials
Content-Type: application/json

{
  "userId": "{{userId}}",
  "providerId": "nanogpt",
  "label": "primary",
  "apiToken": "{{providerApiToken}}"
}
