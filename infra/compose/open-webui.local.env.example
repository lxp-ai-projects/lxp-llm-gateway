# Local lab only.
# This profile assumes:
# - Open WebUI runs on your workstation through Docker Compose
# - gateway-api runs on the host on port 3001
# - the OpenAI-compatible path is trusted only because the whole machine is trusted

OPENAI_API_BASE_URL=http://host.docker.internal:3001/api/v1/openai
OPENAI_API_KEY=change-me

# Local dev intentionally bypasses Open WebUI model filtering so that
# gateway-resolved models remain visible to regular Open WebUI users.
BYPASS_MODEL_ACCESS_CONTROL=true
