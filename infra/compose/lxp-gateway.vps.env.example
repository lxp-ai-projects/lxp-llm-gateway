# Core VPS deployment profile for lxp-llm-gateway.
# Copy to a private file such as `.env.lxp-gateway.vps` before starting Compose.

COMPOSE_PROJECT_NAME=lxp-llm-gateway-vps

LXP_VPS_POSTGRES_DB=lxp_gateway
LXP_VPS_POSTGRES_USER=lxp_gateway
LXP_VPS_POSTGRES_PASSWORD=change-me
LXP_VPS_DATABASE_SSL=false

LXP_VPS_ENCRYPTION_MASTER_KEY=
LXP_VPS_EMAIL_LOOKUP_KEY=
LXP_VPS_ENCRYPTION_KEY_VERSION=1
LXP_VPS_COOKIE_SECRET=
LXP_VPS_JWT_PRIVATE_KEY=

LXP_VPS_REQUEST_BODY_LIMIT=10mb
LXP_VPS_NANOGPT_BASE_URL=https://nano-gpt.com/api/v1

LXP_VPS_ADMIN_WEB_ORIGIN=https://admin.example.com
LXP_VPS_ADMIN_API_PUBLIC_URL=https://admin.example.com
LXP_VPS_GATEWAY_API_PUBLIC_URL=https://gateway.example.com

# OpenAI-compatible gateway integration defaults.
# Keep trusted identity correlation disabled until a real trusted proxy/Open WebUI path exists.
LXP_VPS_OPENAI_COMPAT_API_KEY=change-me
# Keep this aligned with a real gateway user. For the first alpha run, using
# the same email as the first admin is the least surprising path.
LXP_VPS_OPENAI_COMPAT_DEFAULT_USER_EMAIL=admin@example.com
LXP_VPS_OPENAI_COMPAT_TRUSTED_IDENTITY_ENABLED=false
LXP_VPS_OPENAI_COMPAT_TRUSTED_EMAIL_HEADER=X-OpenWebUI-User-Email
LXP_VPS_OPENAI_COMPAT_TRUSTED_EMAIL_HEADERS=
LXP_VPS_OPENAI_COMPAT_DEBUG=false
