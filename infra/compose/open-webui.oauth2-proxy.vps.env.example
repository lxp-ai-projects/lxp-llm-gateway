# VPS / deployed trusted mode with oauth2-proxy.
# This profile assumes:
# - a public reverse proxy sits in front of Open WebUI
# - oauth2-proxy authenticates the human user
# - the proxy re-injects only trusted auth headers such as X-Auth-Request-Email
# - gateway-api accepts only allowlisted trusted email headers

OPENAI_API_BASE_URL=https://gateway.example.com/api/v1/openai
OPENAI_API_KEY=change-me
BYPASS_MODEL_ACCESS_CONTROL=false

OAUTH2_PROXY_PROVIDER=oidc
OAUTH2_PROXY_CLIENT_ID=change-me
OAUTH2_PROXY_CLIENT_SECRET=change-me

# Must be exactly 32 bytes before base64 encoding for oauth2-proxy.
OAUTH2_PROXY_COOKIE_SECRET=change-me
OAUTH2_PROXY_REDIRECT_URL=https://openwebui.example.com/oauth2/callback

# Required when provider=oidc.
OAUTH2_PROXY_OIDC_ISSUER_URL=https://idp.example.com/realms/example
