# VPS / deployed trusted mode.
# This profile assumes:
# - Open WebUI is publicly reachable
# - gateway-api stays on a trusted internal path when possible
# - the public proxy strips caller-supplied identity headers
# - trusted identity correlation is enabled in gateway-api only inside that boundary

OPENAI_API_BASE_URL=https://gateway.example.com/api/v1/openai
OPENAI_API_KEY=change-me

# Prefer false by default. Set to true only when the deployment intentionally
# wants Open WebUI to show the full gateway-returned model list to its users.
BYPASS_MODEL_ACCESS_CONTROL=false
