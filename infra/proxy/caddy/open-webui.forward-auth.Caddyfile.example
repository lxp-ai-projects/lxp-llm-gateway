openwebui.example.com {
  encode gzip

  # Public callers must not be able to preserve or spoof internal identity headers.
  header {
    -X-OpenWebUI-User-Email
    -X-Forwarded-User
    -X-Forwarded-Email
    -X-Auth-Request-User
    -X-Auth-Request-Email
  }

  # Example auth gateway such as oauth2-proxy.
  # It authenticates the user and returns trusted identity headers.
  forward_auth 127.0.0.1:4180 {
    uri /auth
    copy_headers X-Auth-Request-User X-Auth-Request-Email
  }

  reverse_proxy 127.0.0.1:3004 {
    header_up Host {host}
    header_up X-Forwarded-Host {host}
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-For {remote}
  }
}
