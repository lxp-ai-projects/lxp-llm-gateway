server {
  listen 443 ssl http2;
  server_name openwebui.example.com;

  # TLS directives intentionally omitted from the example.

  location / {
    proxy_pass http://127.0.0.1:3004;
    proxy_http_version 1.1;

    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

    # Public callers must not be able to preserve or spoof internal identity headers.
    proxy_set_header X-OpenWebUI-User-Email "";
    proxy_set_header X-Forwarded-User "";
    proxy_set_header X-Forwarded-Email "";
    proxy_set_header X-Auth-Request-User "";
    proxy_set_header X-Auth-Request-Email "";
  }
}
