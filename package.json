{
  "name": "lxp-llm-gateway",
  "private": true,
  "version": "0.1.0",
  "author": {
    "name": "Laurie and Patrick"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "db:migration": "pnpm run db:migration:admin && pnpm run db:migration:gateway",
    "db:migration:admin": "pnpm --filter @lxp/admin-api migration:run",
    "db:migration:gateway": "pnpm --filter @lxp/gateway-api migration:run"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
