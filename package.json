{
  "name": "lxp-llm-gateway",
  "private": true,
  "version": "0.1.0",
  "author": {
    "name": "Laurie and Patrick"
  },
  "packageManager": "pnpm@11.0.7",
  "scripts": {
    "build": "turbo run build",
    "dev:audit": "node ./scripts/audit-dev-scripts.mjs",
    "dev:validate": "node ./scripts/validate-runtime-dev-graph.mjs",
    "dev": "pnpm run dev:check && pnpm run dev:runtime:build && pnpm run dev:runtime",
    "dev:check": "node ./scripts/check-dev-ports.mjs",
    "dev:runtime": "turbo run dev --filter=@lxp/admin-web --concurrency=4",
    "dev:runtime:build": "turbo run build --filter=@lxp/admin-web --filter=@lxp/admin-api --filter=@lxp/gateway-api --concurrency=3",
    "dev:reset-ports": "powershell -ExecutionPolicy Bypass -File ./scripts/reset-dev-ports.ps1",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "db:migration": "pnpm run db:migration:admin && pnpm run db:migration:gateway",
    "db:migration:admin": "pnpm --filter @lxp/admin-api migration:run",
    "db:migration:gateway": "pnpm --filter @lxp/gateway-api migration:run",
    "setup:vps:env:linux": "bash ./scripts/generate-vps-env.sh",
    "setup:vps:env:powershell": "powershell -ExecutionPolicy Bypass -File ./scripts/Generate-VpsEnv.ps1",
    "setup:quickstart": "node ./scripts/setup-quickstart.mjs up",
    "setup:quickstart:down": "node ./scripts/setup-quickstart.mjs down",
    "setup:quickstart:logs": "node ./scripts/setup-quickstart.mjs logs"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
