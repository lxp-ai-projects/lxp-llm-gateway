{
  "name": "@lxp/cli-setup",
  "private": false,
  "version": "0.1.0",
  "description": "First-time setup CLI for lxp-llm-gateway",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "lxp-setup": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lxp-ai-projects/lxp-llm-gateway.git",
    "directory": "packages/cli-setup"
  },
  "bugs": {
    "url": "https://github.com/lxp-ai-projects/lxp-llm-gateway/issues"
  },
  "homepage": "https://github.com/lxp-ai-projects/lxp-llm-gateway/tree/main/packages/cli-setup",
  "keywords": [
    "cli",
    "setup",
    "bootstrap",
    "env",
    "self-hosted",
    "llm-gateway"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "lint": "eslint src --ext .ts",
    "prepack": "pnpm build",
    "test": "pnpm build && node --test dist/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
