    "@lxp/contracts": "workspace:*",
    "@lxp/domain": "workspace:*",
    "@lxp/provider-ollama": "workspace:*",
    "@lxp/provider-nanogpt": "workspace:*",
    "@lxp/provider-openrouter": "workspace:*",
    "@lxp/provider-groq": "workspace:*",
