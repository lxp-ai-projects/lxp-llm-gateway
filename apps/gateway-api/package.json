  "scripts": {
    "build": "tsc -p tsconfig.json",
    "coverage": "tsx --test --experimental-test-coverage src/auth/gateway-auth.service.test.ts src/gateway/gateway.service.test.ts src/gateway/provider-credential.service.test.ts src/gateway/provider-registry.service.test.ts src/images/image-application.service.test.ts src/openai-compatible/openai-compatible.service.test.ts src/persistence/entities/entity-metadata.test.ts",
