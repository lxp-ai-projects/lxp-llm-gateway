    "lint": "eslint src --ext .ts",
    "migration:run": "tsx ./node_modules/typeorm/cli.js migration:run -d src/persistence/data-source.ts",
    "test": "tsx --test src/auth/gateway-auth.service.test.ts src/gateway/gateway.service.test.ts src/gateway/provider-credential.service.test.ts src/gateway/provider-registry.service.test.ts src/images/image-application.service.test.ts src/openai-compatible/openai-compatible.service.test.ts src/persistence/entities/entity-metadata.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.3",
    "tsc-watch": "^6.2.1",
    "tsx": "^4.0.0"
