{
  "name": "@lxp/admin-api",
  "private": true,
  "version": "0.1.0",
  "dependencies": {
    "@lxp/domain": "workspace:*",
    "@lxp/provider-anthropic": "workspace:*",
    "@lxp/provider-deepseek": "workspace:*",
    "@lxp/provider-google": "workspace:*",
    "@lxp/provider-groq": "workspace:*",
    "@lxp/provider-mistral": "workspace:*",
    "@lxp/provider-moonshot": "workspace:*",
    "@lxp/provider-nanogpt": "workspace:*",
    "@lxp/provider-ollama": "workspace:*",
    "@lxp/provider-openai": "workspace:*",
    "@lxp/provider-openrouter": "workspace:*",
    "@lxp/provider-sdk": "workspace:*",
    "@lxp/provider-xai": "workspace:*",
    "@lxp/provider-zai": "workspace:*",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/typeorm": "^11.0.3",
    "@node-rs/argon2": "^2.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "redis": "^6.1.0",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.30"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "coverage": "node ./scripts/run-tests.mjs coverage",
    "dev": "node ../../scripts/run-with-port.mjs 3002 pnpm exec tsc-watch --project tsconfig.json --onSuccess \"node dist/main.js\"",
    "lint": "eslint src --ext .ts",
    "migration:generate": "typeorm-ts-node-commonjs -d src/persistence/data-source.ts migration:generate src/persistence/migrations/GeneratedMigration",
    "migration:run": "tsx ./node_modules/typeorm/cli.js migration:run -d src/persistence/data-source.ts",
    "prepare:test-deps": "pnpm --filter @lxp/domain build && pnpm --filter @lxp/contracts build && pnpm --filter @lxp/provider-sdk build && pnpm --parallel --workspace-concurrency=12 --filter @lxp/provider-anthropic --filter @lxp/provider-deepseek --filter @lxp/provider-google --filter @lxp/provider-groq --filter @lxp/provider-mistral --filter @lxp/provider-moonshot --filter @lxp/provider-nanogpt --filter @lxp/provider-ollama --filter @lxp/provider-openai --filter @lxp/provider-openrouter --filter @lxp/provider-xai --filter @lxp/provider-zai build",
    "precoverage": "pnpm run prepare:test-deps",
    "pretest": "pnpm run prepare:test-deps",
    "test": "node ./scripts/run-tests.mjs test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.3",
    "pg-mem": "^3.0.5",
    "tsx": "^4.0.0",
    "tsc-watch": "^6.2.1",
    "typeorm-ts-node-commonjs": "^0.3.20"
  }
}
