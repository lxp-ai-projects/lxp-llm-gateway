{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "paths": {
      "@lxp/contracts": ["../../packages/contracts/src/index.ts"],
      "@lxp/domain": ["../../packages/domain/src/index.ts"],
      "@lxp/model-family-capabilities": [
        "../../packages/model-family-capabilities/src/index.ts"
      ]
    },
    "types": ["vite/client"],
    "noEmit": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/test/**/*"]
}
